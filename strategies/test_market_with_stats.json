{
  "name": "test_market_with_stats",
  "description": "大行情判断+胜率统计+结合BR下单",
  "step1_regime_detection": {
    "source": "binance",
    "symbols": [
      "BTCUSDT",
      "ETHUSDT",
      "SOLUSDT"
    ],
    "intervals": [
      "1h",
      "4h"
    ],
    "regimes": [
      "trend_up",
      "trend_down",
      "sideways"
    ]
  },
  "step2_stats": {
    "track_by_regime": true,
    "track_by_strategy": [
      "breakout",
      "reversion",
      "range"
    ],
    "track_by_price_range": [
      "low",
      "mid",
      "high"
    ],
    "min_samples": 10
  },
  "step3_select": {
    "select_by": "highest_winrate",
    "require_min_samples": 10
  },
  "step4_copy_br": {
    "enabled": true,
    "br_patterns": [
      "high_price_buy_up",
      "low_price_buy_down"
    ]
  },
  "holdingMinutes": 5,
  "sizeUSD": 20,
  "maxMinsToEnd": 1
}